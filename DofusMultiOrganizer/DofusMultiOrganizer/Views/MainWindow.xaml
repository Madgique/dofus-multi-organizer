<Window
    x:Class="DofusOrganizer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:controls="using:DofusOrganizer.Views.Controls"
    xmlns:vm="using:DofusOrganizer.ViewModels"
    xmlns:converters="using:DofusOrganizer.Converters"
    mc:Ignorable="d"
    Title="Dofus Multi Organizer">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Icône System Tray — vit dans l'arbre XAML mais n'occupe aucun espace visuel -->
        <tb:TaskbarIcon
            x:Name="TrayIcon"
            ToolTipText="Dofus Multi Organizer"
            IconSource="/Assets/TrayIcon.ico"
            LeftClickCommand="{x:Bind ViewModel.ShowWindowCommand}"
            DoubleClickCommand="{x:Bind ViewModel.ShowWindowCommand}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        x:Name="MenuItemSettings"
                        Text="{x:Bind ViewModel.OpenSettingsText, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ShowWindowCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <ToggleMenuFlyoutItem
                        x:Name="MenuItemStartup"
                        Text="{x:Bind ViewModel.StartWithWindowsText, Mode=OneWay}"
                        IsChecked="{x:Bind ViewModel.StartWithWindows, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ToggleStartupCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="MenuItemQuit"
                        Text="{x:Bind ViewModel.QuitText, Mode=OneWay}"
                        Command="{x:Bind ViewModel.QuitCommand}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE7E8;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- Contenu de la fenêtre Settings -->
        <Grid Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Titre + toggle mode + bouton refresh -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    x:Uid="Settings_WindowsTitle"
                    Text="Fenêtres Dofus"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    VerticalAlignment="Center" />
                <ToggleSwitch
                    Grid.Column="1"
                    x:Uid="Settings_ModeToggle"
                    IsOn="{x:Bind ViewModel.IsUnityMode, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />
                <Button
                    Grid.Column="2"
                    x:Uid="Settings_Refresh"
                    Command="{x:Bind ViewModel.RefreshDofusWindowsCommand}"
                    Style="{ThemeResource DefaultButtonStyle}">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>
            </Grid>

            <!-- Entête de colonne -->
            <Grid Grid.Row="1" Padding="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE737;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Grid.Column="2" x:Uid="Settings_ColCharacter" Text="Personnage" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" />
                <TextBlock Grid.Column="4" x:Uid="Settings_ColHotkey" Text="Raccourci" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" />
            </Grid>

            <!-- Liste des fenêtres Dofus (réorderable par drag & drop) -->
            <ListView
                Grid.Row="2"
                x:Name="WindowsListView"
                ItemsSource="{x:Bind ViewModel.DofusWindows, Mode=OneWay}"
                CanReorderItems="True"
                AllowDrop="True"
                SelectionMode="None"
                CanDragItems="True">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DofusWindowViewModel">
                        <controls:DofusWindowRow DataContext="{x:Bind}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0,2" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Hotkeys globaux + options de comportement -->
            <StackPanel Grid.Row="3" Spacing="8">
                <TextBlock
                    x:Uid="Settings_GlobalHotkeys"
                    Text="Raccourcis globaux"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock x:Uid="Settings_PrevWindow" Text="Fenêtre précédente" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <controls:HotkeyBox Hotkey="{x:Bind ViewModel.PrevWindowHotkey, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock x:Uid="Settings_NextWindow" Text="Fenêtre suivante" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <controls:HotkeyBox Hotkey="{x:Bind ViewModel.NextWindowHotkey, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>
                <ToggleSwitch
                    x:Uid="Settings_IgnoreMinimized"
                    IsOn="{x:Bind ViewModel.IgnoreMinimizedWindows, Mode=TwoWay}"
                    Margin="0,4,0,0" />
                <ToggleSwitch
                    x:Uid="Settings_AutoFocus"
                    IsOn="{x:Bind ViewModel.AutoFocusOnTurn, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.RetroOptionsVisibility, Mode=OneWay}"
                    Margin="0,0,0,0" />
            </StackPanel>

            <!-- Langue + Thème + Démarrage avec Windows -->
            <Grid Grid.Row="4" ColumnSpacing="16" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Uid="Settings_Language" Text="Langue" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <ComboBox
                        SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}"
                        HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Français" />
                        <ComboBoxItem Content="English" />
                        <ComboBoxItem Content="Português (BR)" />
                        <ComboBoxItem Content="Español" />
                    </ComboBox>
                    <TextBlock
                        x:Uid="Settings_LangRestartHint"
                        FontSize="10"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Margin="0,2,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock x:Uid="Settings_ThemeLabel" Style="{ThemeResource CaptionTextBlockStyle}" />
                    <ComboBox
                        SelectedIndex="{x:Bind ViewModel.AppTheme, Mode=TwoWay}"
                        HorizontalAlignment="Stretch">
                        <ComboBoxItem x:Uid="Settings_Theme_System" />
                        <ComboBoxItem x:Uid="Settings_Theme_Light" />
                        <ComboBoxItem x:Uid="Settings_Theme_Dark" />
                    </ComboBox>
                </StackPanel>
                <ToggleSwitch
                    Grid.Column="2"
                    x:Uid="Settings_Startup"
                    Header="Démarrer avec Windows"
                    IsOn="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"
                    VerticalAlignment="Bottom" />
            </Grid>

            <!-- Version de l'application -->
            <TextBlock
                Grid.Row="5"
                Text="{x:Bind ViewModel.AppVersion}"
                HorizontalAlignment="Right"
                FontSize="10"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Margin="0,4,0,0" />

        </Grid>
    </Grid>
</Window>
