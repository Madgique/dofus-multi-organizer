<UserControl
    x:Class="DofusOrganizer.Views.Controls.HotkeyBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Button
        x:Name="CaptureButton"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Left"
        MinWidth="0"
        FontSize="12"
        Padding="8,4"
        ToolTipService.ToolTip="Cliquer pour capturer un raccourci"
        Click="CaptureButton_Click"
        KeyDown="CaptureButton_KeyDown"
        LostFocus="CaptureButton_LostFocus">

        <Grid>
            <!-- Raccourci défini -->
            <TextBlock
                x:Name="HotkeyText"
                Visibility="Collapsed" />

            <!-- Aucun raccourci -->
            <TextBlock
                x:Name="EmptyText"
                Text="Aucun"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

            <!-- Mode capture en cours -->
            <TextBlock
                x:Name="CapturingText"
                Text="Appuyez sur une touche…"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontStyle="Italic"
                Visibility="Collapsed" />
        </Grid>
    </Button>
</UserControl>
